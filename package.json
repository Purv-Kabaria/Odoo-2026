{
  "name": "odoo-template",
  "version": "1.0",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset --force",
    "db:reset:populate": "pnpm db:reset && pnpm template:seed && pnpm search:index",
    "db:populate": "pnpm users:generate && pnpm template:seed && pnpm search:index",
    "users:generate": "node scripts/generate-users.js",
    "users:seed": "node scripts/seed-users.js",
    "users:index": "node scripts/index-users-search.js",
    "users:populate": "pnpm users:generate && pnpm users:seed",
    "template:seed": "node scripts/seed-template-data.js",
    "search:index": "node scripts/index-users-search.js",
    "template:refresh": "pnpm template:seed && pnpm search:index",
    "db:wipe": "node scripts/wipe-db.js",
    "db:wipe:table": "node scripts/wipe-table.js",
    "smoke:auth": "node scripts/smoke-auth.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@lottiefiles/react-lottie-player": "^3.5.4",
    "@prisma/client": "6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.1",
    "recharts": "3.8.0",
    "redis": "^6.1.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
